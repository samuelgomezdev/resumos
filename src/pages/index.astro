---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Resumos ADS"
  description="Compilado de anotações e resumos das disciplinas do curso de Análise e Desenvolvimento de Sistemas."
  cssFiles={['home.css']}
>
  <a class="skip-link" href="#main-content">Pular para o conteúdo</a>

  <header>
    <div class="header-inner">
      <a class="logo" href={`${base}/`}>Resumos<span>.dev</span></a>
      <nav>
        <button class="theme-toggle" aria-label="Alternar tema claro/escuro">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="search-btn" id="search-btn" aria-label="Buscar (Ctrl+K)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span class="search-btn-label">Buscar</span><kbd>Ctrl K</kbd>
        </button>
        <a href="https://github.com/marcusteixeirabr/resumos" target="_blank" rel="noopener" aria-label="Ver no GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <main id="main-content" data-pagefind-body>
    <section class="hero">
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
      <div class="hero-glow hero-glow-3"></div>
      <div class="hero-content">
        <div class="hero-badge"><span class="badge-dot"></span>ADS</div>
        <h1>Resumos de <em>ADS</em></h1>
        <p>Compilado de anotações e resumos das disciplinas do curso de Análise e Desenvolvimento de Sistemas. Feito para estudar, revisar e compartilhar.</p>
        <div class="hero-meta">
          <div class="meta-item"><span class="meta-value">4</span><span class="meta-label">Disciplinas</span></div>
          <div class="meta-divider"></div>
          <div class="meta-item"><span class="meta-value">2</span><span class="meta-label">Concluídas</span></div>
          <div class="meta-divider"></div>
          <div class="meta-item"><span class="meta-value">100%</span><span class="meta-label">Open Source</span></div>
        </div>
      </div>
    </section>

    <section class="disciplines">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow">Disciplinas</span>
          <h2>Explore o conteúdo</h2>
        </div>
        <div class="grid">

          <a class="card" href={`${base}/software-design/ua1/`} aria-label="Acessar resumos de Software Design">
            <div class="card-top">
              <div class="card-icon icon-blue" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8l2 2-2 2M11 12h4"/></svg>
              </div>
              <div class="card-status status-progress">Em andamento</div>
            </div>
            <h3>Software Design</h3>
            <p>Arquitetura de sistemas, UML, diagramas de classes, sequência, componentes, prototipação e banco de dados.</p>
            <div class="card-footer">
              <div class="chip-list"><span class="chip">UML</span><span class="chip">Arquitetura</span><span class="chip">DER/MER</span></div>
              <span class="card-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </a>

          <a class="card" href={`${base}/responsive-web/ua1/`} aria-label="Acessar resumos de Responsive Web Development">
            <div class="card-top">
              <div class="card-icon icon-green" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div class="card-status status-progress">Em andamento</div>
            </div>
            <h3>Responsive Web Dev</h3>
            <p>HTML5, CSS3, formulários, JavaScript, AJAX e introdução ao PHP com MySQL para desenvolvimento web.</p>
            <div class="card-footer">
              <div class="chip-list"><span class="chip">HTML5</span><span class="chip">CSS3</span><span class="chip">JS</span></div>
              <span class="card-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </a>

          <a class="card" href={`${base}/engenharia-requisitos/`} aria-label="Engenharia de Requisitos — em breve">
            <div class="card-top">
              <div class="card-icon icon-purple" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
              </div>
              <div class="card-status status-soon">Em breve</div>
            </div>
            <h3>Engenharia de Requisitos</h3>
            <p>Regras de negócio, requisitos funcionais e não funcionais, casos de uso, diagrama de atividades e rastreabilidade.</p>
            <div class="card-footer">
              <div class="chip-list"><span class="chip">RF / RNF</span><span class="chip">Caso de Uso</span><span class="chip">UML</span></div>
              <span class="card-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </a>

          <a class="card" href={`${base}/pensamento-computacional/`} aria-label="Pensamento Computacional — em breve">
            <div class="card-top">
              <div class="card-icon icon-orange" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
              </div>
              <div class="card-status status-soon">Em breve</div>
            </div>
            <h3>Pensamento Computacional</h3>
            <p>Fundamentos de algoritmos, lógica, linguagem C, estruturas de controle, vetores e matrizes.</p>
            <div class="card-footer">
              <div class="chip-list"><span class="chip">Algoritmos</span><span class="chip">Linguagem C</span><span class="chip">Lógica</span></div>
              <span class="card-arrow" aria-hidden="true"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            </div>
          </a>

        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-inner">
      <span>Feito com ♥ para facilitar os estudos</span>
      <a href="https://github.com/marcusteixeirabr/resumos" target="_blank" rel="noopener">@MS</a>
    </div>
  </footer>
</BaseLayout>
