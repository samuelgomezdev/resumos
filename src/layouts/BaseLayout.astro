---
interface Props {
  title: string;
  description?: string;
  cssFiles?: string[];
}

const { title, description = 'Resumos ADS — UNIVALI', cssFiles = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#070710" id="meta-theme-color" />

  <!-- Open Graph / WhatsApp -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://marcusteixeirabr.github.io/resumos/og-image.png`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Favicons -->
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  <link rel="icon" href={`${base}/favicon-32x32.png`} sizes="32x32" type="image/png" />
  <link rel="icon" href={`${base}/favicon-16x16.png`} sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />

  <!-- Inicialização do tema: roda ANTES de qualquer paint para evitar flash -->
  <script is:inline>
    (function () {
      var stored = null;
      try { stored = localStorage.getItem('theme'); } catch(e) {}
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
      var mc = document.getElementById('meta-theme-color');
      if (mc) mc.content = theme === 'light' ? '#f0f4ff' : '#070710';
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/styles/base.css`}>
  {cssFiles.map(f => <link rel="stylesheet" href={`${base}/styles/${f}`} />)}
  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`}>
</head>
<body>
  <slot />

  <!-- Search modal -->
  <div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Buscar no site" aria-hidden="true">
    <div class="search-modal-backdrop" id="search-backdrop"></div>
    <div class="search-modal-inner">
      <div id="search"></div>
    </div>
  </div>

  <!-- Theme toggle logic -->
  <script is:inline>
    (function () {
      function setTheme(t) {
        document.documentElement.classList.add('theme-transitioning');
        document.documentElement.setAttribute('data-theme', t);
        try { localStorage.setItem('theme', t); } catch(e) {}
        var mc = document.getElementById('meta-theme-color');
        if (mc) mc.content = t === 'light' ? '#f0f4ff' : '#070710';
        setTimeout(function () {
          document.documentElement.classList.remove('theme-transitioning');
        }, 320);
      }
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.theme-toggle');
        if (!btn) return;
        var current = document.documentElement.getAttribute('data-theme') || 'dark';
        setTheme(current === 'dark' ? 'light' : 'dark');
      });
    })();
  </script>

  <script is:inline src={`${base}/pagefind/pagefind-ui.js`}></script>
  <script is:inline define:vars={{ base }}>
    (function () {
      var modal    = document.getElementById('search-modal');
      var btn      = document.getElementById('search-btn');
      var backdrop = document.getElementById('search-backdrop');
      var pf;
      function openSearch() {
        if (!pf) pf = new PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
        modal.removeAttribute('aria-hidden');
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        setTimeout(function () { var i = modal.querySelector('input'); if (i) i.focus(); }, 60);
      }
      function closeSearch() {
        modal.setAttribute('aria-hidden', 'true');
        modal.classList.remove('open');
        document.body.style.overflow = '';
      }
      if (btn)      btn.addEventListener('click', openSearch);
      if (backdrop) backdrop.addEventListener('click', closeSearch);
      document.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
        if (e.key === 'Escape' && modal.classList.contains('open')) closeSearch();
      });
    })();
  </script>
</body>
</html>
